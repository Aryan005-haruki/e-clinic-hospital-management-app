<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_50"
    tools:showIn="scroll_view">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/grey_50">

        <!-- Gradient Header -->
        <View
            android:id="@+id/gradient_header"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/gradient_blue_green_vertical" />

        <ImageView
            android:id="@+id/background_image"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="10dp"
            android:adjustViewBounds="true"
            android:scaleType="centerInside"
            android:src="@mipmap/hosp" />

        <!-- Emergency Button Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_emergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/background_image"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/button_emergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_siren"
                android:drawablePadding="20dp"
                android:padding="24dp"
                android:text="Emergency! \nCall An Ambulance"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textColor="@color/error"
                android:textSize="22sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Book Appointment Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_book_appointment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_emergency"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/button_book_appointment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="20dp"
                android:padding="24dp"
                android:text="Book An Appointment"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textColor="@color/blue_700"
                android:textSize="22sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Find Doctors Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_find_doctors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_book_appointment"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/button_find_doctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_doctor"
                android:drawablePadding="20dp"
                android:padding="24dp"
                android:text="Find Doctors!"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textColor="@color/green_700"
                android:textSize="22sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- View Prescriptions Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_prescriptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_find_doctors"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/button_view_prescriptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_checkup"
                android:drawablePadding="20dp"
                android:padding="24dp"
                android:text="View Prescriptions"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textColor="@color/blue_600"
                android:textSize="22sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- Health Precautions Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_health_precautions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_prescriptions"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <Button
                android:id="@+id/button_health_precautions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/ic_medical_record2"
                android:drawablePadding="20dp"
                android:padding="24dp"
                android:text="Health Precautions"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textColor="@color/green_600"
                android:textSize="22sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </RelativeLayout>

</ScrollView>